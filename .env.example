# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Server
PORT=50051

# Environment: development | staging | production
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loan_engine
DB_USER=loan_engine_user
DB_PASSWORD=your_password_here

# Database tuning (optional — defaults shown)
DB_MAX_CONN_RETRIES=10 # how many times to retry on startup
DB_MAX_IDLE_CONNS=10 # idle connections kept in pool
DB_MAX_OPEN_CONNS=100 # max concurrent connections
DB_CONN_MAX_LIFETIME=3600 # seconds before a connection is recycled

# Health check (optional — defaults shown)
HEALTH_CHECK_INTERVAL=30# seconds between DB ping checks

# Goose migrations
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://loan_engine_app:loan_dev@localhost:5432/loan_engine?sslmode=disable
GOOSE_MIGRATION_DIR=./db/migrations
